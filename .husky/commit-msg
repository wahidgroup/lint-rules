#!/usr/bin/env sh
set -e

# Conventional Commits 1.0.0 + @commitlint/config-conventional defaults.
# https://www.conventionalcommits.org/en/v1.0.0/
#
# <type>[optional scope][!]: <description>
# - type/scope: lowercase
# - description: not Sentence/Start/Pascal/UPPER case (must not start with A-Z)
# - no trailing period; header max 100 chars

msg_file="$1"
if [ -z "$msg_file" ] || [ ! -f "$msg_file" ]; then
	echo "ERROR: commit-msg hook missing message file argument." >&2
	exit 1
fi

# First non-comment, non-empty line is the subject (header).
subject=""
while IFS= read -r line || [ -n "$line" ]; do
	case "$line" in
		\#*) continue ;;
	esac
	if [ -n "$line" ]; then
		subject="$line"
		break
	fi
done < "$msg_file"

if [ -z "$subject" ]; then
	echo "ERROR: empty commit message." >&2
	exit 1
fi

# Git-generated subjects (not author Conventional Commits).
case "$subject" in
	Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
		exit 0
		;;
esac

# type-enum + type-case + scope-case + ! + colon-space + subject not empty / not full-stop
# Description must start with a lowercase letter or digit (subject-case never for Sentence-case).
pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9][a-z0-9/-]*\))?(!)?: [a-z0-9].+[^.]$'

if ! printf '%s\n' "$subject" | grep -Eq "$pattern"; then
	cat >&2 <<EOF
ERROR: commit header is not a valid Conventional Commit.

  Expected: <type>[optional scope][!]: <description>
  Types:    build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test
  Type/scope MUST be lowercase
  Description MUST start with a lowercase letter or digit (not Sentence case)
  Description MUST NOT end with a period
  Spec:     https://www.conventionalcommits.org/en/v1.0.0/

  Got: $subject
EOF
	exit 1
fi

# header-max-length (commitlint default)
maxlen=100
len=$(printf '%s' "$subject" | wc -c | tr -d ' ')
if [ "$len" -gt "$maxlen" ]; then
	echo "ERROR: commit header is ${len} characters (max ${maxlen})." >&2
	echo "  Got: $subject" >&2
	exit 1
fi
