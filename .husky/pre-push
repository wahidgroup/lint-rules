set -e
make lint

remote="$1"

while read local_ref local_oid remote_ref remote_oid; do
	if [ "$local_oid" = "0000000000000000000000000000000000000000" ]; then
		continue
	fi

	exclude=$(git for-each-ref --format='%(objectname)' "refs/remotes/$remote/")
	exclude_args=""
	for ref in $exclude; do
		exclude_args="$exclude_args ^$ref"
	done

	for commit in $(eval git rev-list "$local_oid" $exclude_args); do
		if ! git verify-commit "$commit" 2>/dev/null; then
			echo "ERROR: Commit $commit has an invalid or missing signature."
			echo "       All commits must have a valid signature before pushing."
			exit 1
		fi
	done
done
