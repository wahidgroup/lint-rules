#!/usr/bin/env sh
set -e

# Husky invokes this via `sh -e` (.husky/_/h).
# Redirect stdin so make/npm cannot consume the ref list git feeds this hook.
if ! make lint </dev/null; then
	echo "ERROR: make lint failed; push aborted."
	exit 1
fi

z40=0000000000000000000000000000000000000000

# Range per git's sample pre-push hook (githooks): remote_oid..local_oid.
while read local_ref local_oid remote_ref remote_oid; do
	if [ "$local_oid" = "$z40" ]; then
		continue
	fi

	if [ "$remote_oid" = "$z40" ]; then
		range="$local_oid"
	else
		range="$remote_oid..$local_oid"
	fi

	for commit in $(git rev-list "$range"); do
		if ! git verify-commit "$commit" 2>/dev/null; then
			echo "ERROR: Commit $commit has an invalid or missing signature."
			echo "       All commits must have a valid signature before pushing."
			exit 1
		fi
	done
done
